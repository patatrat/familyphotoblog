# Neon Postgres pooled connection string (used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DATABASE?sslmode=require"

# Neon direct (non-pooler) URL — used by Prisma migrations only
# Same as DATABASE_URL but remove "-pooler" from the hostname
DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.REGION.aws.neon.tech/DATABASE?sslmode=require"

# Vercel Blob token (from Vercel dashboard → Storage → Blob → Token)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_XXXXXXXXXXXXXXXX"

# NextAuth secret — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32-output"

# Required on Vercel deployments
AUTH_TRUST_HOST="true"

# Forward Email SMTP connection string
# Format: smtp://user:password@smtp.forwardemail.net:587
EMAIL_SERVER="smtp://no-reply%40photos.radomski.co.nz:PASSWORD@smtp.forwardemail.net:587"

# From address for magic link and notification emails
EMAIL_FROM="no-reply@photos.radomski.co.nz"

# Public URL of the deployed app (no trailing slash)
NEXT_PUBLIC_APP_URL="https://photos.radomski.co.nz"

# Family passphrase required at signup (shared with family out-of-band)
SIGNUP_PASSPHRASE="replace-with-family-passphrase"
